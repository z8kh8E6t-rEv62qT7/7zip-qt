# .clang-format
#
# 建议用法：
#   clang-format -style=file -i path/to/file.cc
#
# 版本建议：
#   这份主配置尽量按 clang-format 16+ 写。
#   如果某个键报 Unknown key，说明本地 clang-format 版本较旧，把该键注释掉即可。
#
# 重要：
#   1. 不建议团队成员各自使用系统自带不同版本的 clang-format。
#   2. 建议在 CI / pre-commit / devcontainer 中固定 clang-format 版本。
#   3. 不要把所有官方选项都硬塞进去；这里只放基础项 + 常用项 + 实战中很有用的高级项。

---
# ============================================================
# 1. 基础设置
# ============================================================

Language: Cpp
# 当前配置段适用于 C/C++/Objective-C++。
# 如果项目里有 JavaScript / JSON / Proto，可以在文件底部再加多段 Language 配置。

BasedOnStyle: LLVM
# 基础风格。
# 常见值：
#   LLVM      ：LLVM 默认风格，很多 C++ 项目会以此为基础。
#   Google    ：Google C++ Style。
#   Chromium  ：Chromium 风格。
#   Mozilla   ：Mozilla 风格。
#   WebKit    ：WebKit 风格。
#   Microsoft ：MSVC / Visual Studio 风格。
#   GNU       ：GNU 风格。
#
# 建议：
#   先选一个接近项目审美的 BasedOnStyle，再局部覆盖。
#   不建议从零开始定义所有规则。

Standard: c++20
# C++ 语法标准。
# 常见值：
#   Auto   ：自动推断。
#   c++03 / c++11 / c++14 / c++17 / c++20
#   Latest ：使用 clang-format 支持的最新 C++ 语法。
#
# 建议：
#   现代项目显式写 c++17 或 c++20。
#   如果项目跨多个标准，可以用 Auto。

DisableFormat: false
# 是否完全禁用格式化。
# false：正常格式化。
# true ：此 Language 段完全不格式化。
#
# 局部禁用通常用：
#   // clang-format off
#   ...
#   // clang-format on

AlwaysBreakTemplateDeclarations: Yes
ConstructorInitializerAllOnOneLineOrOnePerLine: false

ColumnLimit: 120
# 每行最大列宽。
# 常见值：
#   80  ：传统风格，适合终端/内核类项目。
#   100 ：现代 C++ 项目常用。
#   120 ：业务项目常用。
#   0   ：不主动按列宽换行。
#
# 建议：
#   库代码/开源项目可用 100。
#   业务代码可用 100 或 120。

LineEnding: LF
# 换行符。
# 常见值：
#   LF       ：使用 \n，Linux/macOS 常用。
#   CRLF     ：使用 \r\n，Windows 常用。
#   DeriveLF ：优先 LF，但会根据输入文件推断。
#   DeriveCRLF：优先 CRLF，但会根据输入文件推断。

InsertNewlineAtEOF: true
# 文件末尾是否补一个换行。
# true：推荐，符合多数 Unix 工具链习惯。

MaxEmptyLinesToKeep: 1
# 最多保留连续空行数量。
# 1：推荐；过多空行会被压缩成 1 行。

SeparateDefinitionBlocks: Always
# class/struct/enum/function 等定义块之间是否自动插入/删除空行。
# 常见值：
#   Leave ：保持原样。
#   Always：定义块之间强制空一行。
#   Never ：删除定义块之间的空行。
#
# 建议：
#   对已有项目用 Leave，减少无意义 diff。
#   新项目想统一更强，可用 Always。


# ============================================================
# 2. 缩进、Tab、续行
# ============================================================

UseTab: Never
# 是否使用 tab。
# 常见值：
#   Never                         ：永不用 tab，推荐。
#   ForIndentation                ：只在缩进中使用 tab。
#   ForContinuationAndIndentation ：缩进和续行都可用 tab。
#   Always                        ：尽量使用 tab。
#
# 建议：
#   跨平台项目一般用 Never。

IndentWidth: 4
# 基础缩进宽度。
# 常见值：
#   2：Google/Chromium/很多前端或大型单仓库常用。
#   4：传统 C++/企业项目常用。

TabWidth: 4
# tab 显示宽度。
# 即使 UseTab: Never，也建议显式写，避免编辑器显示差异。

ContinuationIndentWidth: 4
# 续行缩进宽度。
# 例如函数调用参数换行、表达式换行后的额外缩进。

ConstructorInitializerIndentWidth: 4
# 构造函数初始化列表、继承列表的续行缩进宽度。

BracedInitializerIndentWidth: -1
# braced initializer 内部缩进宽度。
# -1：沿用 ContinuationIndentWidth。
# 例如：
#   SomeType value{
#       a,
#       b,
#   };

AccessModifierOffset: -4
# public:/private:/protected: 相对 class 内成员的缩进偏移。
# 在 IndentWidth: 4 时：
#   -4：public: 顶到 class 内层左侧，常见。
#    0：public: 和成员同级缩进。
#
# 示例：
# class Foo {
# public:
#     void f();
# private:
#     int x_;
# };

IndentAccessModifiers: false
# true ：public/private/protected 自己占一个缩进层级。
# false：由 AccessModifierOffset 控制。
#
# 建议：
#   如果已经设置 AccessModifierOffset，通常保持 false。

IndentWrappedFunctionNames: false
# 函数声明/定义返回类型换行后，函数名是否再缩进。
# false：函数名不额外缩进，比较紧凑。
# true ：函数名额外缩进。

IndentCaseLabels: true
# switch 的 case/default 标签是否缩进。
#
# false：
# switch (x) {
# case 1:
#     break;
# }
#
# true：
# switch (x) {
#     case 1:
#         break;
# }

IndentCaseBlocks: true
# case 后如果有代码块，代码块是否再额外缩进。
#
# 通常 false 即可，避免 switch 过深。

IndentGotoLabels: true
# goto label 是否缩进。
# 一般保持 true。

IndentExternBlock: Indent
# extern "C" 块内部如何缩进。
# 常见值：
#   AfterExternBlock：根据 extern block 位置缩进。
#   Indent          ：总是缩进。
#   NoIndent        ：不缩进。
#
# C/C++ 混编头文件较多时可以关注此项。

LambdaBodyIndentation: Signature
# lambda 函数体缩进依据。
# Signature ：相对 lambda 签名缩进，默认且常用。
# OuterScope：相对外层作用域缩进，复杂嵌套 lambda 时可能更清爽。


# ============================================================
# 3. namespace、class、作用域
# ============================================================

NamespaceIndentation: All
# namespace 内部是否额外缩进。
# 常见值：
#   None ：namespace 内部不额外缩进，很多大型 C++ 项目常用。
#   Inner：只缩进嵌套 namespace。
#   All  ：所有 namespace 都缩进。
#
# 建议：
#   多层 namespace 的现代 C++ 项目建议 None，避免整体右移过多。

CompactNamespaces: true
# 是否压缩连续 namespace。
#
# true：
# namespace A { namespace B {
# ...
# }} // namespace A::B
#
# false：
# namespace A {
# namespace B {
# ...
# } // namespace B
# } // namespace A

FixNamespaceComments: true
# 是否自动补全/修正 namespace 结束注释。
#
# true：
# namespace foo {
# ...
# } // namespace foo

ShortNamespaceLines: 1
# 短 namespace 的最大行数。
# 短 namespace 可以不补 namespace 结束注释。
# 例如设为 1，则只有一行内容的 namespace 可省略结束注释。

# clang-format 20+ 可用：
WrapNamespaceBodyWithEmptyLines: Always
# namespace body 首尾空行处理方式。
# 常见值：
#   Leave ：保留原样。
#   Never ：移除 namespace body 开头/结尾空行。
#   Always：namespace body 开头/结尾至少保留一个空行。


# ============================================================
# 4. 大括号风格
# ============================================================

BreakBeforeBraces: Attach
# 大括号换行风格。
# 常见值：
#   Attach     ：左大括号贴在声明/语句后，K&R 风格。
#   Linux      ：Linux 风格。
#   Mozilla    ：Mozilla 风格。
#   Stroustrup ：Stroustrup 风格。
#   Allman     ：左大括号独立一行。
#   GNU        ：GNU 风格。
#   WebKit     ：WebKit 风格。
#   Custom     ：使用下面 BraceWrapping 逐项控制。
#
# 建议：
#   如果团队想精确控制，用 Custom。

# BraceWrapping:
#   AfterCaseLabel: false
#   # case 标签后是否让大括号独立一行。

#   AfterClass: false
#   # class 后左大括号是否换行。
#   # false：class Foo {
#   # true ：class Foo
#   #       {

#   AfterStruct: false
#   # struct 后左大括号是否换行。

#   AfterUnion: false
#   # union 后左大括号是否换行。

#   AfterEnum: false
#   # enum 后左大括号是否换行。

#   AfterFunction: false
#   # 函数定义左大括号是否换行。
#   # false：
#   # void f() {
#   # }
#   #
#   # true：
#   # void f()
#   # {
#   # }

#   AfterNamespace: false
#   # namespace 后左大括号是否换行。

#   AfterObjCDeclaration: false
#   # Objective-C 声明后是否换行。

#   AfterControlStatement: Never
#   # if/for/while/switch 等控制语句后左大括号是否换行。
#   # 常见值：
#   #   Never    ：永不换行，if (x) {
#   #   MultiLine：条件本身多行时才换行。
#   #   Always   ：总是换行。

#   BeforeElse: false
#   # else 前是否换行。
#   #
#   # false：
#   # } else {
#   #
#   # true：
#   # }
#   # else {

#   BeforeCatch: false
#   # catch 前是否换行。

#   BeforeLambdaBody: false
#   # lambda body 的左大括号前是否换行。

#   BeforeWhile: false
#   # do-while 的 while 前是否换行。

#   IndentBraces: false
#   # 大括号本身是否缩进。

#   SplitEmptyFunction: false
#   # 空函数是否拆成多行。
#   #
#   # false：void f() {}
#   # true ：void f() {
#   #       }

#   SplitEmptyRecord: false
#   # 空 class/struct/union 是否拆成多行。

#   SplitEmptyNamespace: false
#   # 空 namespace 是否拆成多行。


# ============================================================
# 5. 短语句是否允许放在一行
# ============================================================

AllowShortBlocksOnASingleLine: Empty
# 短代码块是否允许单行。
# 常见值：
#   Never ：从不。
#   Empty ：只允许空块，例如 {}
#   Always：短块都可单行。
#
# 建议：
#   Empty 比较稳，不会把逻辑压太紧。

AllowShortEnumsOnASingleLine: false
# 短 enum 是否放一行。
#
# false：
# enum Color {
#     Red,
#     Green,
# };

AllowShortFunctionsOnASingleLine: Inline
# 短函数是否允许单行。
# Empty ：空函数允许一行，例如 void f() {}
# Inline：类内 inline 短函数允许一行。
# Other ：普通函数定义是否允许一行。
#
# 建议：
#   Empty/Inline 可以 true。
#   Other 通常 false，避免实现逻辑被压成一行。

AllowShortIfStatementsOnASingleLine: Never
# 短 if 是否允许一行。
# 常见值：
#   Never       ：永不。
#   WithoutElse ：没有 else 时允许。
#   OnlyFirstIf ：只允许 if 链第一段。
#   AllIfsAndElse：if/else 都可短行。
#
# 建议：
#   C++ 项目通常 Never，避免可读性下降。

AllowShortLoopsOnASingleLine: false
# 短 for/while/do-while 是否允许一行。
# 建议 false。

AllowShortCaseLabelsOnASingleLine: false
# 短 case 是否允许一行。
#
# false：
# case 1:
#     return true;

AllowShortLambdasOnASingleLine: Inline
# 短 lambda 是否允许单行。
# 常见值：
#   None  ：不允许。
#   Empty ：只允许空 lambda。
#   Inline：作为函数参数等 inline 场景允许。
#   All   ：全部短 lambda 都允许。
#
# 建议：
#   Inline 对 STL algorithm / ranges 比较友好。

AllowShortNamespacesOnASingleLine: false
# 短 namespace 是否压成一行。
# 建议 false。

AllowShortCompoundRequirementOnASingleLine: false
# clang-format 18+。
# C++20 requires compound requirement 是否允许一行。
# 如果本地 clang-format < 18，遇到 Unknown key 就注释掉。


# ============================================================
# 6. 函数参数、调用参数、括号、换行
# ============================================================

AlignAfterOpenBracket: true
# 左括号后换行时，是否对齐到括号后的位置。
#
# true：
# foo(long_argument,
#     second_argument);
#
# false：
# foo(long_argument,
#     second_argument);
#
# 注意：
#   不同版本对此项的可选值有过调整。
#   如果版本较旧，可能见到 Align / DontAlign / AlwaysBreak / BlockIndent 等写法。

BinPackArguments: false
# 函数调用参数是否尽量塞在同一行。
#
# false：
# foo(a,
#     b,
#     c);
#
# true：
# foo(a, b,
#     c);
#
# 建议：
#   追求 diff 友好：false。
#   追求紧凑：true。

BinPackParameters: false
# 函数声明/定义参数是否尽量塞在同一行。
#
# false：
# void foo(int a,
#          int b,
#          int c);
#
# true：
# void foo(int a, int b,
#          int c);
#
# 注意：
#   clang-format 23 开始推荐用 PackParameters / PackArguments。
#   旧项目仍大量使用 BinPackArguments / BinPackParameters。

AllowAllArgumentsOnNextLine: true
# 当函数调用参数放不下时，是否允许所有参数整体移到下一行。
#
# true：
# very_long_function_name(
#     a, b, c);
#
# 配合 BinPackArguments: false 时，通常仍倾向每个参数一行。

AllowAllParametersOfDeclarationOnNextLine: true
# 函数声明/定义参数放不下时，是否允许整体移到下一行。

ExperimentalAutoDetectBinPacking: false
# 是否自动探测当前文件已有的 bin packing 风格。
# 建议 false，避免同一项目中格式随文件历史风格漂移。

BreakBeforeBinaryOperators: NonAssignment
# 二元运算符换行位置。
# 常见值：
#   None          ：在运算符后断行。
#   NonAssignment ：非赋值运算符前断行，赋值运算符后断行。
#   All           ：所有二元运算符前断行。
#
# 建议：
#   NonAssignment 可读性较好：
#   bool ok = very_long_condition
#             && another_condition;

BreakBeforeTernaryOperators: true
# 三目运算符 ? : 是否放在新行开头。
#
# true：
# cond
#     ? a
#     : b

AlignOperands: AlignAfterOperator
# 多行表达式中操作数是否对齐。
# 常见值：
#   DontAlign          ：不对齐。
#   Align              ：对齐操作数。
#   AlignAfterOperator ：在操作符前断行时，让操作数对齐得更自然。

BreakStringLiterals: false
# 超过 ColumnLimit 时是否拆分长字符串字面量。
# true：允许拆。
# false：长字符串保持不拆。

AlwaysBreakBeforeMultilineStrings: false
# 多行字符串前是否总是强制换行。
# 一般保持 false。

BreakBeforeConceptDeclarations: Always
# C++20 concept 声明中 template 和 concept 是否换行。
#
# Always：
# template <typename T>
# concept C = ...;
#
# Never：
# template <typename T> concept C = ...;

RequiresClausePosition: OwnLineWithBrace
# C++20 requires 子句位置。
# 常见值：
#   OwnLine          ：requires 单独一行。
#   OwnLineWithBrace ：requires 单独一行，但函数体 { 可跟随。
#   WithPreceding    ：尽量贴着前面的 template/参数。
#   WithFollowing    ：尽量贴着后面的声明。
#   SingleLine       ：能一行就一行。
#
# 建议：
#   concepts 较多的现代 C++ 项目建议 OwnLine 或 OwnLineWithBrace。

IndentRequiresClause: true
# requires 子句是否缩进。
# 仅在 RequiresClausePosition 为 OwnLine / OwnLineWithBrace / WithFollowing 时明显生效。

RequiresExpressionIndentation: OuterScope
# requires 表达式 body 缩进方式。
# OuterScope：相对外层作用域缩进，默认且常用。
# Keyword   ：相对 requires 关键字缩进。

# clang-format 23+ 新写法，可替代 BinPackArguments / BinPackParameters。
# 如果启用下面两项，建议注释掉上面的 BinPackArguments / BinPackParameters。
#
# PackArguments:
#   BinPack: OnePerLine
#   # 函数调用参数打包方式。
#   # BinPack     ：尽量塞一行。
#   # OnePerLine  ：放不下时每个参数一行。
#   # UseBreakAfter：超过 BreakAfter 数量后每个参数一行。
#   # BreakAfter: 3
#
# PackParameters:
#   BinPack: OnePerLine
#   # 函数声明/定义参数打包方式。
#   # BinPack          ：尽量塞一行。
#   # OnePerLine       ：放不下时每个参数一行。
#   # AlwaysOnePerLine ：总是每个参数一行。
#   # UseBreakAfter    ：超过 BreakAfter 数量后每个参数一行。
#   # BreakAfter: 3


# ============================================================
# 7. 构造函数初始化列表、继承列表
# ============================================================

BreakConstructorInitializers: AfterColon
# 构造函数初始化列表断行方式。
# 常见值：
#   BeforeColon：在冒号前断行。
#   BeforeComma：在冒号和逗号前断行。
#   AfterColon ：在冒号后断行。
#   AfterComma ：只在逗号后断行。
#
# BeforeColon 示例：
# Foo::Foo()
#     : a_(1),
#       b_(2) {}
BreakConstructorInitializersBeforeComma: false

PackConstructorInitializers: NextLine
# 构造函数初始化列表是否打包。
# 常见值：
#   Never        ：每个 initializer 一行。
#   BinPack      ：尽量打包。
#   CurrentLine  ：当前行能放下就放当前行，否则每个一行。
#   NextLine     ：当前行放不下时，尝试下一行打包。
#   NextLineOnly ：只尝试下一行打包，否则每个一行。
#
# 建议：
#   成员多的 C++ 类，NextLine 或 Never 更清晰。

BreakInheritanceList: BeforeColon
# class 继承列表断行方式。
# 常见值：
#   BeforeColon：冒号前断行。
#   BeforeComma：冒号和逗号前断行。
#   AfterColon ：冒号后断行。
#   AfterComma ：只在逗号后断行。
#
# BeforeColon 示例：
# class Derived
#     : public Base1,
#       public Base2 {
# };


# ============================================================
# 8. 指针、引用、const/volatile 限定符
# ============================================================

DerivePointerAlignment: false
# 是否从已有文件中自动推断 * 和 & 的对齐风格。
# false：使用 PointerAlignment / ReferenceAlignment。
# true ：根据当前文件已有风格推断。
#
# 建议：
#   团队统一风格时用 false。

PointerAlignment: Left
# 指针 * 的位置。
# 常见值：
#   Left  ：int* p;
#   Right ：int *p;
#   Middle：int * p;
#
# 现代 C++ 项目常用 Left 或 Right，选一个即可。

SpaceInEmptyParentheses: false

ReferenceAlignment: Pointer
# 引用 & 的位置。
# 常见值：
#   Pointer：沿用 PointerAlignment。
#   Left   ：int& r;
#   Right  ：int &r;
#   Middle ：int & r;
#
# 建议：
#   如果 PointerAlignment: Left，则 ReferenceAlignment: Pointer 得到 int& r。

SpaceAroundPointerQualifiers: Default
# 指针限定符周围空格。
# 例如 const、volatile、restrict 出现在指针附近时。
# 常见值：
#   Default：默认行为。
#   Before ：限定符前加空格。
#   After  ：限定符后加空格。
#   Both   ：前后都加空格。
#
# 一般保持 Default。

# QualifierAlignment: Leave
# const/volatile/static/inline 等限定符位置是否重排。
# 常见值：
#   Leave ：不改变，最安全。
#   Left  ：倾向 const int。
#   Right ：倾向 int const。
#   Custom：使用 QualifierOrder。
#
# 强烈建议：
#   默认 Leave。
#   因为 clang-format 不是完整语义分析器，强行重排 qualifier 有风险。

# 如果确实要统一 east const / west const，可谨慎开启：
QualifierAlignment: Custom

QualifierOrder: [inline, static, constexpr, type, const, volatile]


# ============================================================
# 9. 空格风格
# ============================================================

SpaceBeforeParens: ControlStatements
# 左括号前空格。
# 常见值：
#   Never             ：函数和控制语句都不加空格，if(x)。
#   ControlStatements ：只在 if/for/while/switch 后加空格，if (x)。
#   Always            ：函数调用也加空格，f ()。
#   Custom            ：使用 SpaceBeforeParensOptions 精细控制。
#
# 建议：
#   C/C++ 项目通常 ControlStatements。

# 如需精细控制，可改成：
# SpaceBeforeParens: Custom
# SpaceBeforeParensOptions:
#   AfterControlStatements: true
#   AfterForeachMacros: true
#   AfterFunctionDeclarationName: false
#   AfterFunctionDefinitionName: false
#   AfterFunctionDefinitionName: false
#   AfterIfMacros: true
#   AfterOverloadedOperator: false
#   BeforeNonEmptyParentheses: false

SpaceBeforeAssignmentOperators: true
# 赋值运算符前后是否加空格。
#
# true：
# a = b;

SpaceBeforeCpp11BracedList: false
# C++11 braced initializer 前是否加空格。
#
# false：
# Foo foo{1, 2};
#
# true：
# Foo foo {1, 2};

SpaceBeforeCtorInitializerColon: true
# 构造函数初始化列表冒号前是否加空格。
#
# Foo::Foo() : a_(1) {}

SpaceBeforeInheritanceColon: true
# 继承列表冒号前是否加空格。
#
# class D : public B {};

SpaceBeforeRangeBasedForLoopColon: true
# range-for 冒号前是否加空格。
#
# for (auto x : xs)

SpaceBeforeSquareBrackets: false
# 方括号前是否加空格。
#
# false：
# arr[i]
#
# true：
# arr [i]

SpacesInAngles: Never
# 模板尖括号内部是否加空格。
# 常见值：
#   Never ：std::vector<int>
#   Always：std::vector< int >
#   Leave ：保持原样。

SpacesInConditionalStatement: false
SpacesInCStyleCastParentheses: false
SpacesInParentheses: false
SpacesInParens: Never
# 圆括号内部是否加空格。
#
# Never：
# f(a, b)
#
# Always：
# f( a, b )

SpacesInSquareBrackets: false
# 方括号内部是否加空格。
#
# false：
# arr[i]

SpaceAfterCStyleCast: false
# C 风格 cast 后是否加空格。
#
# false：
# (int)x
#
# true：
# (int) x

SpaceAfterTemplateKeyword: true
# template 关键字后是否加空格。
#
# true：
# template <typename T>

SpacesBeforeTrailingComments: 1
# 行尾注释前至少保留几个空格。
#
# int x = 0; // comment

BitFieldColonSpacing: Both
# 位域冒号周围空格。
#
# Both：
# unsigned x : 1;
#
# None：
# unsigned x:1;

Cpp11BracedListStyle: true
# C++11 braced list 是否按函数调用风格处理。
# true 通常更符合现代 C++。
#
# std::vector<int> v{1, 2, 3};


# ============================================================
# 10. 对齐
# ============================================================

AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 0
# 行尾注释对齐。
# Kind:
#   Leave ：保留原样。
#   Always：对齐相邻行尾注释。
#   Never ：不对齐。
# OverEmptyLines:
#   允许跨多少个空行继续对齐。
#
# 建议：
#   OverEmptyLines: 0，避免跨大段代码强行对齐。

AlignConsecutiveAssignments:
  Enabled: false
  AcrossEmptyLines: false
  AcrossComments: false
  AlignCompound: false
  PadOperators: false
# 连续赋值是否对齐。
#
# true 可能得到：
# int short_name      = 1;
# int very_long_name = 2;
#
# 建议：
#   默认 false，减少无意义 diff。
#   配置表/寄存器表/大量常量定义可局部开启。

AlignConsecutiveDeclarations:
  Enabled: false
  AcrossEmptyLines: false
  AcrossComments: false
  AlignFunctionDeclarations: false
  AlignFunctionPointers: false
# 连续声明是否对齐。
# 默认 false，避免变量名变长导致大面积 diff。

AlignConsecutiveMacros:
  Enabled: false
  AcrossEmptyLines: false
  AcrossComments: false
# 连续宏定义是否对齐。
#
# 可考虑在 C 项目或头文件宏表中开启：
# #define A      1
# #define LONG_B 2

AlignConsecutiveBitFields:
  Enabled: false
  AcrossEmptyLines: false
  AcrossComments: false
# 连续 bit-field 是否对齐。
# 嵌入式/协议结构体项目可能有用。

AlignEscapedNewlines: Right
# 反斜杠续行的对齐方式，常见于宏。
# 常见值：
#   DontAlign
#   Left
#   LeftWithLastLine
#   Right
#
# 宏较多的 C/C++ 项目可以关注。

AlignArrayOfStructures: None
# 结构体数组初始化是否按列对齐。
# 常见值：
#   None ：不对齐，推荐默认。
#   Left ：左对齐。
#   Right：右对齐。
#
# 对表驱动代码可能有用，但会增加 diff。


# ============================================================
# 11. include / using 排序与分组
# ============================================================

SortIncludes:
  Enabled: true
  IgnoreCase: false
# 是否排序 #include。
# Enabled:
#   true ：启用 include 排序。
#   false：保持 include 原顺序。
# IgnoreCase:
#   true ：排序时忽略大小写。
#   false：区分大小写。

IncludeBlocks: Regroup
# 多个 include 块如何处理。
# 常见值：
#   Preserve：每个 include 块内部排序，但不合并块。
#   Merge   ：合并所有 include 块并排序。
#   Regroup ：合并排序后，再按 IncludeCategories 重新分组。
#
# 建议：
#   想统一 include 分组，用 Regroup。
#   不想大面积改动旧项目，用 Preserve。

IncludeCategories: 
  - Regex: '^<.*'
    Priority: 1
  - Regex: '^".*'
    Priority: 2
  - Regex: '.*'
    Priority: 3

IncludeIsMainRegex: '([-_](test|unittest))?$'

# 判断 main header 的文件名后缀。
#
# 例如：
#   foo.cc       -> foo.h
#   foo_test.cc  -> foo.h
#   foo-unittest.cc -> foo.h
#
# 这个配置可以让测试文件也正确识别对应主头文件。

IncludeIsMainSourceRegex: ''
# 哪些源文件参与 main include 推断。
# 默认通常够用。
# 如果项目有特殊源文件扩展，可以在这里配置正则。

SortUsingDeclarations: Lexicographic
# using 声明排序方式。
# 常见值：
#   Never        ：不排序。
#   Lexicographic：字典序排序。
#   LexicographicNumeric：带数字感知的字典序。
#
# 建议：
#   通常用 Lexicographic。


# ============================================================
# 12. 注释
# ============================================================

ReflowComments: Always
# 是否重排长注释。
# 常见值：
#   Never     ：不改注释内容换行。
#   IndentOnly：只调整缩进。
#   Always    ：根据 ColumnLimit 重排注释。
#
# 建议：
#   如果注释里经常有 Markdown 表格/ASCII 图，考虑 Never 或 IndentOnly。
#   普通源码注释可用 Always。

CommentPragmas: '^ IWYU pragma:'
# 保护有特殊语义的注释，不让 clang-format 乱改。
# 常见场景：
#   // IWYU pragma: keep
#   // IWYU pragma: export
#
# 如果项目有自定义工具注释，可以扩展这个正则。

OneLineFormatOffRegex: '^(// NOLINT|// clang-format off-line)'
# 单行禁用格式化的正则。
#
# 例：
#   // NOLINT
#   some_ugly_but_required_code();
#
# 或者：
#   some_ugly_but_required_code(); // clang-format off-line

# 局部禁用仍可使用：
#   // clang-format off
#   ...
#   // clang-format on


# ============================================================
# 13. 宏相关：非常有用，尤其是 Qt/Boost/OpenSSL/内核式 C 项目
# ============================================================

ForEachMacros:
  - foreach
  - Q_FOREACH
  - BOOST_FOREACH
# 把这些宏当作 foreach/for 语句处理。
#
# 适合：
#   Qt 老项目
#   Boost 老代码
#   自定义 FOREACH 宏

IfMacros:
  - KJ_IF_MAYBE
# 把这些宏当作 if 语句处理。
#
# 适合：
#   if-like 宏，例如：
#   IF_SOMETHING(x) {
#       ...
#   }

StatementMacros:
  - Q_UNUSED
  - QT_REQUIRE_VERSION
# 把这些宏当作完整语句处理。
#
# 适合：
#   Q_UNUSED(x)
#   DCHECK(...)
#   CUSTOM_ASSERT(...)

StatementAttributeLikeMacros:
  - Q_EMIT
  - emit
# 把这些宏当作语句前 attribute 一类的东西。
# Qt 项目中 emit/Q_EMIT 很常见。

AttributeMacros:
  - __capability
  - __output
  - __unused
# 把这些宏当作 attribute/qualifier，而不是普通标识符。
#
# 适合：
#   编译器扩展
#   静态分析注解
#   安全标注
#   平台相关 API 注解

TypenameMacros:
  - STACK_OF
  - LIST
# 把这些宏当作类型声明。
#
# 适合：
#   OpenSSL: STACK_OF(...)
#   BSD queue/list 宏
#   某些 C 框架类型宏

WhitespaceSensitiveMacros:
  - STRINGIZE
  - PP_STRINGIZE
  - BOOST_PP_STRINGIZE
# 这些宏内部空白敏感，不应被 clang-format 改动。
#
# 适合：
#   字符串化宏
#   Boost.Preprocessor
#   复杂预处理元编程

MacroBlockBegin: ''
# 匹配“宏块开始”的正则。
#
# 例如项目有：
#   NS_MAP_BEGIN
#     ...
#   NS_MAP_END
#
# 可以配置：
# MacroBlockBegin: '^NS_MAP_BEGIN$'
# MacroBlockEnd: '^NS_MAP_END$'

MacroBlockEnd: ''
# 匹配“宏块结束”的正则。

SkipMacroDefinitionBody: false
# 是否跳过宏定义体的格式化。
# true：不格式化 #define 后面的宏体。
#
# 如果项目里有大量复杂多行宏，且 clang-format 经常改坏，可设 true。
# 默认 false。


# ============================================================
# 14. Raw string / 嵌入式 DSL
# ============================================================

RawStringFormats:
  - Language: TextProto
    Delimiters:
      - pb
      - proto
    EnclosingFunctions:
      - PARSE_TEXT_PROTO
    BasedOnStyle: Google

  - Language: Cpp
    Delimiters:
      - cc
      - cpp
    BasedOnStyle: LLVM
    CanonicalDelimiter: cc
# raw string 内部格式化规则。
#
# 适合：
#   R"pb(... )pb"              -> 按 TextProto 格式化。
#   PARSE_TEXT_PROTO(R"(... )") -> 按 TextProto 格式化。
#   R"cc(... )cc"              -> 按 C++ 格式化。
#
# 如果项目在 C++ 中嵌入 SQL / JSON / TextProto / C++ 片段，这个非常有用。


# ============================================================
# 15. C++ 现代特性和其它安全项
# ============================================================

BreakAfterJavaFieldAnnotations: false
# Java 专用；C++ 项目无影响。
# 如果没有 Java 代码，可以保留默认或删除。

BreakBeforeInlineASMColon: OnlyMultiline
# inline asm 冒号前是否换行。
# 常见值：
#   Never        ：不强制。
#   OnlyMultiline：多行 inline asm 时才处理。
#   Always       ：总是换行。
#
# 有内联汇编的低层项目可关注。

RemoveSemicolon: false
# 是否移除函数/构造函数定义大括号后的多余分号。
#
# 强烈建议 false。
# 因为这类“删除 token”的行为可能因 clang-format 缺少完整语义信息而有风险。

InsertBraces: false
# 是否给没有大括号的 if/for/while 自动插入大括号。
#
# 强烈建议 false。
# 虽然统一加大括号有价值，但这属于改写代码结构，应交给 clang-tidy 或人工 review。

IntegerLiteralSeparator:
  Binary: 0
  BinaryMinDigits: 0
  Decimal: 0
  DecimalMinDigits: 0
  Hex: 0
  HexMinDigits: 0
# 整数字面量分隔符。
#
# 0  ：保持原样。
# 正数：按位数插入分隔符。
# 负数：移除分隔符。
#
# 例如 C++14 起可写：
#   1'000'000
#
# 建议：
#   默认保持 0，避免无意义 diff。


# ============================================================
# 16. Objective-C / JavaScript / JSON 相关
#     C++ 项目通常可以保留默认或删除
# ============================================================

ObjCBinPackProtocolList: Auto
# Objective-C protocol list 是否 bin-pack。
# C++ 项目无影响。

ObjCBlockIndentWidth: 4
# Objective-C block 缩进宽度。
# C++ 项目无影响。

ObjCBreakBeforeNestedBlockParam: true
# Objective-C 嵌套 block 参数前是否换行。
# C++ 项目无影响。

ObjCSpaceAfterProperty: false
# Objective-C @property 后是否加空格。
# C++ 项目无影响。

ObjCSpaceBeforeProtocolList: true
# Objective-C protocol list 前是否加空格。
# C++ 项目无影响。

JavaScriptQuotes: Leave
# JavaScript 字符串引号风格。
# Leave ：保持原样。
# Single：统一单引号。
# Double：统一双引号。

JavaScriptWrapImports: true
# JavaScript import/export 是否换行。
# 如果项目没有 JS，可忽略。

# JSON 专用：
# BreakArrays: true
# JSON 数组是否强制展开。
# 仅 Language: Json 段生效。


# ============================================================
# 17. Penalty：高级调参，一般不建议一开始就改
# ============================================================

PenaltyBreakAssignment: 2
# 打断赋值表达式的代价。
# 值越高，越不愿意在赋值附近断行。

PenaltyBreakBeforeFirstCallParameter: 19
# 函数调用在第一个参数前断行的代价。

PenaltyBreakComment: 300
# 打断注释的代价。
# 值越高，越不愿意重排注释。

PenaltyBreakFirstLessLess: 120
# ostream << 链在第一个 << 处断行的代价。

PenaltyBreakString: 1000
# 打断字符串字面量的代价。
# 值越高，越不愿意拆字符串。

PenaltyBreakTemplateDeclaration: 10
# template 声明后断行的代价。

PenaltyExcessCharacter: 1000000
# 超过 ColumnLimit 每个字符的惩罚。
# 值越高，越强烈避免超列宽。

PenaltyReturnTypeOnItsOwnLine: 60
# 函数返回类型单独成行的惩罚。
# 值越高，越不愿意把返回类型单独放一行。

PenaltyIndentedWhitespace: 0
# 缩进空白字符的惩罚。
# 一般保持默认即可。


# ============================================================
# 18. clang-format 19/20/21/22/23+ 新项参考
#     如果你确认团队版本足够新，可以按需打开
# ============================================================

# ============================================================
# clang-format 19+：空行保留策略
# ============================================================

KeepEmptyLines:
  AtStartOfFile: false
  # 是否保留文件开头的空行。
  #
  # false：
  #   删除文件最前面的多余空行。
  #
  # true：
  #   允许保留文件开头已有空行。
  #
  # 建议：
  #   通常设为 false，避免源码文件开头出现无意义空行。

  AtStartOfBlock: false
  # 是否保留代码块开头的空行。
  #
  # false：
  #   if (cond) {
  #       doSomething();
  #   }
  #
  # true：
  #   if (cond) {
  #
  #       doSomething();
  #   }
  #
  # 建议：
  #   通常设为 false，让 block 开头更紧凑。
  #   如果团队喜欢在大块逻辑开头留视觉分隔，可以设 true。

  AtEndOfFile: false
  # 是否保留文件末尾的多余空行。
  #
  # false：
  #   删除 EOF 前的多余空行，只保留必要的最终换行。
  #
  # true：
  #   允许文件末尾存在额外空行。
  #
  # 建议：
  #   通常设为 false。
  #   注意它不是控制“文件末尾是否有换行”；那个由 InsertNewlineAtEOF 控制。

# 说明：
#   KeepEmptyLines 控制“哪些位置的空行允许被保留”。
#   MaxEmptyLinesToKeep 控制“连续空行最多保留几行”。
#
# 推荐组合：
#   MaxEmptyLinesToKeep: 1
#   KeepEmptyLines:
#     AtStartOfFile: false
#     AtStartOfBlock: false
#     AtEndOfFile: false


# ============================================================
# clang-format 20+：namespace body 首尾空行
# ============================================================

# WrapNamespaceBodyWithEmptyLines: Leave
# 控制 namespace 内部开头和结尾是否保留/插入/删除空行。
#
# 可选值：
#   Never：
#     删除 namespace body 开头和结尾的空行。
#
#     namespace N {
#     void f();
#     } // namespace N
#
#   Always：
#     namespace body 开头和结尾至少保留一个空行。
#
#     namespace N {
#
#     void f();
#
#     } // namespace N
#
#   Leave：
#     保持原样，但仍受 MaxEmptyLinesToKeep 限制。
#
# 建议：
#   旧项目：Leave，减少无意义 diff。
#   新项目：Never，风格更紧凑。
#   不太建议 Always，容易让 namespace 很多的文件变松散。


# ============================================================
# clang-format 20+：二元表达式断行策略
# ============================================================

BreakBinaryOperations: RespectPrecedence
# 控制二元运算表达式在超过 ColumnLimit 时如何断行。
#
# 注意：
#   推荐写法是：
#     BreakBinaryOperations: RespectPrecedence
#
#   不建议写成：
#     BreakBinaryOperations:
#       RespectPrecedence: true
#
# 可选值：
#   Never：
#     不主动把二元操作链拆成“每个操作一行”。
#     可能只在必要处做普通换行。
#
#   OnePerLine：
#     二元操作链如果需要换行，倾向每个操作一行。
#
#     a +
#     b +
#     c
#
#   RespectPrecedence：
#     按运算符优先级更自然地断行。
#     例如乘法/加法/逻辑运算混合时，不会机械地所有操作都一行一个。
#
# 建议：
#   普通 C++ 项目：RespectPrecedence。
#   想要非常紧凑：Never。
#   想要表达式 diff 更规整：OnePerLine。

# clang-format 23+ 也支持更细的结构化写法：
#
# BreakBinaryOperations:
#   Default: RespectPrecedence
#   # 默认二元运算符断行策略。
#   #
#   # 可选值：
#   #   Never
#   #   OnePerLine
#   #   RespectPrecedence
#
#   PerOperator:
#     - Operators: ['&&', '||']
#       Style: OnePerLine
#       MinChainLength: 3
#       # 对指定运算符单独设置规则。
#       #
#       # Operators:
#       #   运算符列表，例如 ['&&', '||']、['|']、['+']。
#       #
#       # Style:
#       #   这些运算符使用的断行策略。
#       #
#       # MinChainLength:
#       #   操作数链达到多少个时触发规则。
#       #   例如 a && b && c 是长度 3。
#       #   0 表示只要超过列宽就可触发。


# ============================================================
# clang-format 21+：长 braced initializer list 的打包策略
# ============================================================

BinPackLongBracedList: false
# braced initializer list 元素很多时，是否特殊启用 bin-pack。
#
# 触发场景：
#   当 braced initializer list 中元素数量很多时，例如 20 个或更多。
#
# false：
#   遵循普通 BinPackArguments / PackArguments 规则。
#   如果你设置了参数一行一个，这里也会更倾向一行一个。
#
#   std::vector<int> xs{
#       1,
#       2,
#       3,
#       ...
#   };
#
# true：
#   对很长的 braced initializer list 尽量压缩打包。
#
#   std::vector<int> xs{1, 2, 3, ..., 20, 21};
#
# 建议：
#   配置表、测试数据、数组初始化较多且希望 diff 清晰：false。
#   大量纯数字列表、追求紧凑：true。


# ============================================================
# clang-format 21+：enum 末尾逗号
# ============================================================

EnumTrailingComma: Leave
# 控制 enum 枚举项列表末尾逗号。
#
# 可选值：
#   Leave：
#     保持原样，不主动插入或删除。
#
#   Insert：
#     尝试给 enum 最后一项插入 trailing comma。
#
#   Remove：
#     尝试删除 enum 最后一项后的 trailing comma。
#
# 建议：
#   强烈建议 Leave。
#
# 原因：
#   Insert / Remove 会主动改 token。
#   官方文档也提醒：由于 clang-format 没有完整语义信息，
#   非 Leave 可能导致不正确的代码格式化，需要额外 review。
#
# 示例：
#   enum Color {
#       Red,
#       Green,
#       Blue,
#   };
#
#   enum Color {
#       Red,
#       Green,
#       Blue
#   };


# ============================================================
# clang-format 22+：左括号后是否强制换行
# ============================================================

BreakAfterOpenBracketFunction: false
# 函数声明、函数定义、函数调用的参数超过 ColumnLimit 时，
# 是否强制在左括号后换行。
#
# false：
#   foo(a,
#       b);
#
# true：
#   foo(
#       a,
#       b);
#
# 建议：
#   false 更紧凑。
#   true 更规整，适合团队偏好“参数列表块状展开”的风格。

BreakAfterOpenBracketIf: false
# if / if constexpr 条件表达式超过 ColumnLimit 时，
# 是否强制在左括号后换行。
#
# false：
#   if (very_long_condition ||
#       another_condition) {
#   }
#
# true：
#   if (
#       very_long_condition ||
#       another_condition) {
#   }
#
# 建议：
#   通常 false。
#   true 会让复杂条件更块状，但也可能显得过度换行。

BreakAfterOpenBracketLoop: false
# for / while / do-while 等循环条件超过 ColumnLimit 时，
# 是否强制在左括号后换行。
#
# false：
#   while (very_long_condition &&
#          another_condition) {
#   }
#
# true：
#   while (
#       very_long_condition &&
#       another_condition) {
#   }
#
# 建议：
#   通常 false。
#   对复杂循环条件特别多的项目，可以考虑 true。

BreakAfterOpenBracketSwitch: false
# switch 条件表达式超过 ColumnLimit 时，
# 是否强制在左括号后换行。
#
# false：
#   switch (very_long_expression +
#           another_expression) {
#   }
#
# true：
#   switch (
#       very_long_expression +
#       another_expression) {
#   }
#
# 建议：
#   通常 false。
#   switch 条件一般不应太复杂；如果经常触发，可能应先考虑重构表达式。


# 可选补充：braced initializer list 的左大括号后换行
# BreakAfterOpenBracketBracedList: false
# braced initializer list 超过 ColumnLimit 时，
# 是否强制在左大括号后换行。
#
# false：
#   std::vector<int> xs{1,
#                       2,
#                       3};
#
# true：
#   std::vector<int> xs{
#       1,
#       2,
#       3};
#
# 仅在 Cpp11BracedListStyle: true 时明显相关。


# ============================================================
# clang-format 22+：右括号前是否强制换行
# ============================================================

BreakBeforeCloseBracketFunction: false
# 函数声明、函数定义、函数调用的参数超过 ColumnLimit 时，
# 是否强制在右括号前换行。
#
# false：
#   foo(
#       a,
#       b);
#
# true：
#   foo(
#       a,
#       b
#   );
#
# 建议：
#   false 更符合大多数 C++ 项目。
#   true 更接近“参数列表独立块”的风格。

BreakBeforeCloseBracketIf: false
# if / if constexpr 条件表达式超过 ColumnLimit 时，
# 是否强制在右括号前换行。
#
# 注意：
#   只有在左括号后已经换行时，这个选项才会明显生效。
#
# false：
#   if (
#       a || b) {
#   }
#
# true：
#   if (
#       a || b
#   ) {
#   }
#
# 建议：
#   通常 false。
#   如果 BreakAfterOpenBracketIf: true，并且团队想形成完整块状结构，可设 true。

BreakBeforeCloseBracketLoop: false
# for / while / do-while 等循环条件超过 ColumnLimit 时，
# 是否强制在右括号前换行。
#
# 注意：
#   通常和 BreakAfterOpenBracketLoop 配合使用。
#
# false：
#   while (
#       a && b) {
#   }
#
# true：
#   while (
#       a && b
#   ) {
#   }
#
# 建议：
#   通常 false。
#   如果循环条件很复杂且希望括号结构更对称，可以设 true。

BreakBeforeCloseBracketSwitch: false
# switch 条件表达式超过 ColumnLimit 时，
# 是否强制在右括号前换行。
#
# 注意：
#   通常和 BreakAfterOpenBracketSwitch 配合使用。
#
# false：
#   switch (
#       a + b) {
#   }
#
# true：
#   switch (
#       a + b
#   ) {
#   }
#
# 建议：
#   通常 false。


# 可选补充：braced initializer list 的右大括号前换行
# BreakBeforeCloseBracketBracedList: false
# braced initializer list 超过 ColumnLimit 时，
# 是否强制在右大括号前换行。
#
# 注意：
#   通常需要左大括号后已经发生换行时才明显生效。
#
# false：
#   std::vector<int> xs{
#       1,
#       2,
#       3};
#
# true：
#   std::vector<int> xs{
#       1,
#       2,
#       3
#   };
#
# 建议：
#   大多数 C++ 项目 false。
#   如果团队喜欢 initializer list 像独立块一样闭合，可设 true。

# ============================================================
# clang-format 23+：函数调用参数 / 函数声明参数的打包策略
# ============================================================
#
# 说明：
#   clang-format 23 起，官方文档中：
#
#     BinPackArguments
#     BinPackParameters
#
#   被新的结构化配置替代：
#
#     PackArguments
#     PackParameters
#
#   PackArguments  控制“函数调用”的实参格式：
#
#     foo(a, b, c);
#
#   PackParameters 控制“函数声明 / 函数定义”的形参格式：
#
#     void foo(int a, int b, int c);
#
# 注意：
#   下面给出两种推荐写法。
#   不要同时启用两套。
#
#   方案 A：
#     放得下一行就保持一行；
#     放不下时，每个参数一行。
#
#   方案 B：
#     参数数量超过指定阈值后，每个参数一行；
#     未超过阈值时，仍允许 bin-pack。
#
# ============================================================


# ------------------------------------------------------------
# 方案 A：推荐默认方案，diff 友好
# ------------------------------------------------------------

# PackArguments:
#   BinPack: OnePerLine
  # 函数调用实参的打包方式。
  #
  # OnePerLine 含义：
  #   如果所有实参能放在当前行，就保持一行。
  #   如果放不下，就每个实参单独一行。
  #
  # 示例：
  #
  #   foo(a, b, c);
  #
  #   veryLongFunctionName(
  #       first_argument,
  #       second_argument,
  #       third_argument);
  #
  # 可选值：
  #   BinPack：
  #     尽量把多个实参塞到同一行。
  #
  #     foo(long_argument_1, long_argument_2,
  #         long_argument_3);
  #
  #   OnePerLine：
  #     当前行能放下就保持一行；
  #     放不下时，每个实参一行。
  #
  #   UseBreakAfter：
  #     使用 BreakAfter 控制超过多少个实参后强制一行一个。
  #     如果没有超过 BreakAfter 阈值，则行为类似 BinPack。
  #
  # 建议：
  #   普通 C++ 项目推荐 OnePerLine。
  #   它比 BinPack 更稳定，后续新增参数时 diff 更清晰。

# PackParameters:
#   BinPack: OnePerLine
  # 函数声明 / 函数定义形参的打包方式。
  #
  # OnePerLine 含义：
  #   如果所有形参能放在当前行，就保持一行。
  #   如果放不下，就每个形参单独一行。
  #
  # 示例：
  #
  #   void foo(int a, int b, int c);
  #
  #   void veryLongFunctionName(
  #       int first_parameter,
  #       int second_parameter,
  #       int third_parameter);
  #
  # 可选值：
  #   BinPack：
  #     尽量把多个形参塞到同一行。
  #
  #   OnePerLine：
  #     当前行能放下就保持一行；
  #     放不下时，每个形参一行。
  #
  #   AlwaysOnePerLine：
  #     无论是否能放下，始终每个形参一行。
  #
  #     void foo(
  #         int a,
  #         int b,
  #         int c);
  #
  #   UseBreakAfter：
  #     使用 BreakAfter 控制超过多少个形参后强制一行一个。
  #     如果没有超过 BreakAfter 阈值，则行为类似 BinPack。
  #
  # 建议：
  #   普通项目推荐 OnePerLine。
  #   如果团队非常强调声明整齐，可以考虑 AlwaysOnePerLine。


# ------------------------------------------------------------
# 方案 B：超过指定数量后才强制一行一个
# ------------------------------------------------------------
#
# 如果你想表达：
#
#   参数数量 <= 3：
#     尽量保持紧凑，可以 bin-pack。
#
#   参数数量 > 3：
#     每个参数单独一行。
#
# 应使用 UseBreakAfter，而不是 OnePerLine。
#
# 注意：
#   BreakAfter 只有在 BinPack: UseBreakAfter 时才应使用。
#   不建议写成：
#
#     BinPack: OnePerLine
#     BreakAfter: 3
#
# 因为 OnePerLine 本身不依赖 BreakAfter 阈值。


# PackArguments:
#   BinPack: UseBreakAfter
#   BreakAfter: 3
#   # 函数调用实参数量超过 3 个时，每个实参一行。
#   #
#   # 示例：
#   #
#   #   foo(1);
#   #
#   #   bar(1, 2, 3);
#   #
#   #   baz(1,
#   #       2,
#   #       3,
#   #       4);
#   #
#   # 说明：
#   #   foo 有 1 个实参，不触发。
#   #   bar 有 3 个实参，不触发。
#   #   baz 有 4 个实参，超过 BreakAfter: 3，触发一行一个。

# PackParameters:
#   BinPack: UseBreakAfter
#   BreakAfter: 3
#   # 函数声明 / 函数定义形参数量超过 3 个时，每个形参一行。
#   #
#   # 示例：
#   #
#   #   void foo(int a);
#   #
#   #   void bar(int a, int b, int c);
#   #
#   #   void baz(int a,
#   #            int b,
#   #            int c,
#   #            int d);
#   #
#   # 说明：
#   #   foo 有 1 个形参，不触发。
#   #   bar 有 3 个形参，不触发。
#   #   baz 有 4 个形参，超过 BreakAfter: 3，触发一行一个。


# ------------------------------------------------------------
# 旧版本写法对照
# ------------------------------------------------------------
#
# clang-format 23 之前，常见写法是：
#
#   BinPackArguments: false
#   BinPackParameters: false
#
# 大致对应新的：
#
#   PackArguments:
#     BinPack: OnePerLine
#
#   PackParameters:
#     BinPack: OnePerLine
#
# 如果项目中仍有开发者使用 clang-format 22 或更旧版本，
# 就不要启用 PackArguments / PackParameters；
# 继续使用旧的 BinPackArguments / BinPackParameters。
#
# 如果团队已经统一到 clang-format 23+，
# 建议迁移到 PackArguments / PackParameters。